<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>SWANAND | Swadeshi Ka Anand</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/css/style.css">
</head>

<body>

<!-- ================= NAVBAR ================= -->
<header class="navbar">
  <div class="brand">
    <img src="/images/logo.png" alt="SWANAND Logo">
    <span>SWANAND</span>
  </div>

  <div class="search">
    <input
      id="search"
      type="text"
      placeholder="Search products..."
      onkeyup="searchProducts()"
      autocomplete="off"
    >
  </div>

  <div class="nav-right">
    <a href="/cart">🛒 Cart (<span id="cart-count">0</span>)</a>
  </div>
</header>

<!-- ================= HERO ================= -->
<section class="hero">
  <h1>Swadeshi Ka Anand</h1>
  <p>Pure • Natural • Premium</p>
</section>

<!-- ================= PRODUCTS ================= -->
<section class="products">
  <div class="grid" id="product-grid">

    <% Object.values(products).forEach(product => { %>

      <div class="card product-card">

        <span class="badge">BEST SELLER</span>

        <!-- CLICKABLE PRODUCT -->
        <a href="/product/<%= product.id %>" class="product-link">

          <img
            src="<%= product.image %>"
            alt="<%= product.name %>"
            loading="lazy"
          >

          <h3 class="product-title"><%= product.name %></h3>

        </a>

        <div class="rating">⭐⭐⭐⭐☆ <span>(214)</span></div>

        <p class="price">₹<%= product.price %></p>

        <div class="card-actions">
          <button
            class="btn-cart"
            onclick='addToCart(<%- JSON.stringify(product) %>)'>
            Add to Cart
          </button>

          <button
            class="btn-buy"
            onclick='buyNow(<%- JSON.stringify(product) %>)'>
            Buy Now
          </button>
        </div>

      </div>

    <% }) %>

  </div>

  <p id="no-product" class="no-product" style="display:none;">
    No products found
  </p>
</section>

<footer>
  © 2026 SWANAND • Made in India 🇮🇳
</footer>

<script src="/js/cart.js"></script>

</body>
</html>
